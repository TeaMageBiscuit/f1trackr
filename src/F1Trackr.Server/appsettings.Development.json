{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "viteRoute": {
        "ClusterId": "viteCluster",
        "Match": {
          "Path": "/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeader": "X-Forwarded-Host", "Set": "{OriginalHost}" },
          { "RequestHeader": "X-Forwarded-Proto", "Set": "{OriginalScheme}" }
        ]
      }
    },
    "Clusters": {
      "viteCluster": {
        "Destinations": {
          "d1": {
            "Address": "http://frontend/"
          }
        }
      }
    }
  }
}
